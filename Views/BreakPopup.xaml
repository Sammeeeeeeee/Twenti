<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Twenti.Views.BreakPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Twenti.Views">

    <Grid x:Name="Root"
          Background="Transparent"
          Padding="20"
          KeyDown="OnKeyDown"
          IsTabStop="True">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title + cycle -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="TitleText"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       Text="Break time"/>
            <Border Grid.Column="1"
                    VerticalAlignment="Center"
                    CornerRadius="6"
                    Padding="10,4"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <TextBlock x:Name="CycleText"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="1/3"/>
            </Border>
        </Grid>

        <!-- Body host swaps between Prompt and Timer -->
        <Grid Grid.Row="1">
            <!-- Prompt state -->
            <StackPanel x:Name="PromptPanel" Spacing="0" Visibility="Visible">
                <TextBlock x:Name="PromptHeading"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           Text="Eye break!"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="PromptBody"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Look 20 feet away for 20 seconds."
                           Margin="0,0,0,18"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="StartButton"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Padding="0,9"
                            CornerRadius="4"
                            Style="{ThemeResource AccentButtonStyle}"
                            FontFamily="{StaticResource AppFont}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Click="OnStart">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="StartButtonLabel" Text="Start 20 sec" HorizontalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="6,1"
                                    CornerRadius="4"
                                    Background="#33FFFFFF">
                                <TextBlock Text="↵" FontSize="11"/>
                            </Border>
                        </Grid>
                    </Button>
                    <Button x:Name="SnoozeButton"
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Padding="0,9"
                            CornerRadius="4"
                            FontFamily="{StaticResource AppFont}"
                            FontSize="13"
                            Click="OnSnooze">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Snooze" HorizontalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Padding="6,1"
                                    CornerRadius="4"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <TextBlock Text="esc" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </Border>
                        </Grid>
                    </Button>
                </Grid>

                <!-- Auto-snooze countdown bar + caption -->
                <Border Height="3"
                        CornerRadius="2"
                        Margin="0,0,0,5"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <Grid HorizontalAlignment="Stretch">
                        <Border x:Name="AutoSnoozeFill"
                                Background="{ThemeResource TextFillColorTertiaryBrush}"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Width="0"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="AutoSnoozeCaption"
                           HorizontalAlignment="Center"
                           FontSize="10"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="Auto-snoozing in 12s · press 1–9 to snooze that many minutes"/>
            </StackPanel>

            <!-- Timer state -->
            <StackPanel x:Name="TimerPanel" Spacing="0" Visibility="Collapsed">
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="TimerNumber"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="56"
                               FontWeight="Bold"
                               Text="20"
                               LineHeight="56"
                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,0,8" Spacing="2">
                        <TextBlock x:Name="TimerUnit"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="seconds"/>
                        <TextBlock FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Text="remaining"/>
                    </StackPanel>
                </Grid>
                <Border Height="6"
                        CornerRadius="3"
                        Margin="0,0,0,10"
                        Background="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <Grid HorizontalAlignment="Stretch">
                        <Border x:Name="TimerFill"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="3"
                                HorizontalAlignment="Left"
                                Width="0"/>
                    </Grid>
                </Border>
                <TextBlock HorizontalAlignment="Center"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="esc to pause · 1–9 to snooze N minutes"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
