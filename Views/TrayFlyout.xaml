<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Twenti.Views.TrayFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Twenti.Views">

    <Grid x:Name="Root"
          Background="Transparent"
          Padding="12"
          KeyDown="OnKeyDown"
          IsTabStop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title row + cycle badge -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock x:Name="LabelText"
                           FontSize="11"
                           FontFamily="{StaticResource AppFont}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="Next break in" />
                <TextBlock x:Name="TimeText"
                           FontSize="26"
                           FontWeight="Bold"
                           FontFamily="{StaticResource AppFont}"
                           Text="20m 00s"
                           Foreground="{ThemeResource StatusGreenBrush}">
                    <TextBlock.OpticalMarginAlignment>TrimSideBearings</TextBlock.OpticalMarginAlignment>
                </TextBlock>
            </StackPanel>
            <Border Grid.Column="1"
                    VerticalAlignment="Top"
                    CornerRadius="5"
                    Padding="7,3"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <TextBlock x:Name="CycleText"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="1/3" />
            </Border>
        </Grid>

        <!-- Progress bar -->
        <Border Grid.Row="1"
                Height="5"
                CornerRadius="3"
                Margin="0,0,0,10"
                Background="{ThemeResource ControlStrokeColorDefaultBrush}">
            <Grid HorizontalAlignment="Stretch">
                <Border x:Name="ProgressFill"
                        Background="{ThemeResource StatusGreenBrush}"
                        CornerRadius="3"
                        HorizontalAlignment="Left"
                        Width="0" />
            </Grid>
        </Border>

        <!-- Primary action -->
        <Button x:Name="StartNowButton"
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                CornerRadius="4"
                Style="{ThemeResource AccentButtonStyle}"
                Padding="0,7"
                FontFamily="{StaticResource AppFont}"
                FontSize="12"
                FontWeight="SemiBold"
                Click="OnStartNow"
                Content="Start break now" />

        <!-- Snooze actions: two buttons by default; swapped for a hint
             label while waiting for a custom-snooze keypress. -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid x:Name="SnoozeButtonsRow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="Snooze15"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Padding="0,5"
                        CornerRadius="4"
                        FontSize="12"
                        FontFamily="{StaticResource AppFont}"
                        Content="Snooze 15m"
                        Click="OnSnooze15"/>
                <Button x:Name="SnoozeCustom"
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Padding="0,5"
                        CornerRadius="4"
                        FontSize="12"
                        FontFamily="{StaticResource AppFont}"
                        Content="Custom…"
                        Click="OnSnoozeCustom"/>
            </Grid>
            <Border x:Name="CustomHintBox"
                    Visibility="Collapsed"
                    CornerRadius="4"
                    Padding="8,6"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           Text="Press 1–9 to snooze that many minutes · Esc to cancel"/>
            </Border>
        </Grid>
    </Grid>
</Window>
